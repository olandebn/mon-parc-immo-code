rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Photos des biens (upload réservé aux admins) ──────────────────────────
    // Seul un utilisateur authentifié avec le rôle ADMIN peut écrire
    // Lecture publique pour afficher les photos sur les pages publiques
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // max 10 MB
        && request.resource.contentType.matches('image/.*');
    }

    // ── Documents (upload réservé aux admins) ─────────────────────────────────
    match /documents/{allPaths=**} {
      allow read: if request.auth != null;   // lecture : utilisateur connecté seulement
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;  // max 20 MB
    }

    // ── Tout le reste : interdit ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
