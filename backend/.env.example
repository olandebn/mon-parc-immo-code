# ================================================
# MonParcImmo - Variables d'environnement Backend
# Sur Railway : ajouter dans Service > Variables
# ================================================

# Firebase - JSON du compte de service encodé en base64
# Comment générer : cat firebase-service-account.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2Vydmlj...

# Email SMTP (Gmail recommandé avec mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ton.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Email de l'administrateur (reçoit les notifications de nouvelles réservations)
ADMIN_EMAIL=admin@monparcimmo.fr

# URL du frontend Vercel (sans slash final)
# Exemple : https://mon-parc-immo.vercel.app
FRONTEND_URL=https://ton-app.vercel.app

# Railway injecte PORT automatiquement - ne pas modifier
# PORT=8080
