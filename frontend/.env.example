# ================================================
# MonParcImmo - Variables d'environnement Frontend
# Copier ce fichier en .env.local pour le développement
# Sur Vercel : ajouter ces variables dans Project Settings > Environment Variables
# ================================================

# URL de l'API backend (Railway en production, vide en dev car proxy Vite prend le relais)
# Exemple prod : https://mon-parc-immo-backend.up.railway.app
VITE_API_URL=

# Firebase - Récupérer depuis Firebase Console > Paramètres du projet > Vos applications
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=mon-parc-immo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mon-parc-immo
VITE_FIREBASE_STORAGE_BUCKET=mon-parc-immo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
